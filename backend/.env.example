# backend/.env — copy to backend/.env and fill in real values; never commit .env

POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=datamarketplace
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
SECRET_KEY=replace-with-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=2
FRONTEND_URL=http://localhost:3000

# Email verification + mailer (social-login plan Phase 1). MAILER unset/"log" =
# LogMailer (dev/CI: logs, sends nothing). "ses" = AWS SES (needs MAIL_FROM = a
# verified sender; creds from the task role). PUBLIC_API_URL is the API's public
# base, used to build the verification link in the email.
MAILER=log
# MAIL_FROM=no-reply@rowbound.com
PUBLIC_API_URL=http://localhost:3001
EMAIL_VERIFICATION_EXPIRE_HOURS=24

# Payments. DEMO/DEV MODE is the default: with STRIPE_USE_REAL=false (or no
# STRIPE_SECRET_KEY) the app uses FakePaymentProvider — no real charges, no Stripe
# account needed; requests AND catalog purchases settle in the ledger only, so the
# whole platform runs end-to-end for demos/dev. Set STRIPE_USE_REAL=true WITH a real
# STRIPE_SECRET_KEY to move real money (buyers charged, suppliers transferred — which
# then requires each supplier to have a connected Stripe account).
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_USE_REAL=false

# Storage. DEV/MinIO: set S3_ENDPOINT_URL + AWS keys (below). REAL AWS S3: leave
# S3_ENDPOINT_URL unset, set USE_S3=true + AWS_REGION + S3_BUCKET, and supply NO
# static keys — the ECS task role provides them. Unset all → LocalStorage (disk).
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123
S3_BUCKET=local-bucket
S3_ENDPOINT_URL=http://localhost:9000
# USE_S3=true
# AWS_REGION=eu-west-1
# DATABASE_URL=  # optional: full postgres URL (overrides POSTGRES_* — used in prod)

# --- Encryption & key management (rowbound-encryption-key-management.md) ------
# E1.3 app->Postgres TLS. Dev/CI default "prefer" (works against plaintext local
# Postgres). PRODUCTION must raise this: "require" to force TLS, or "verify-full"
# (+ DB_SSLROOTCERT pointing at the RDS CA bundle) to also authenticate the server.
DB_SSLMODE=prefer
# DB_SSLROOTCERT=/etc/ssl/certs/rds-combined-ca-bundle.pem

# E3 presigned-URL hardening. The URL is the access grant, so keep it short.
PRESIGNED_URL_TTL_SECONDS=300       # 5 min (was 3600); clamped to the ceiling below
PRESIGNED_URL_TTL_MAX=900           # hard ceiling — a misconfig can't exceed this
# PRESIGNED_ALLOW_HTTP=true         # dev-only escape hatch for local MinIO over http

# E2 bucket-default SSE-KMS. Set to a customer-managed KMS key ARN/ID in prod so
# objects are written under a key you control/rotate/audit. Unset = SSE-S3/none
# (MinIO dev). RDS/Secrets Manager KMS is configured in Terraform, not here.
# S3_SSE_KMS_KEY_ID=arn:aws:kms:...:key/...

# E5 application-level envelope encryption for sensitive (PII-bearing) datasets.
# With ENVELOPE_KMS_KEY_ID set, sensitive uploads are stored as ciphertext whose
# data key is KMS-wrapped; the app/Rust roles unwrap via kms:Decrypt to process &
# deliver. Unset = LocalKeyProvider dev fallback (NOT for real personal data).
# ENVELOPE_KMS_KEY_ID=arn:aws:kms:...:key/...
# ENVELOPE_ENCRYPTION_ENABLED=true  # force on in dev (uses LocalKeyProvider)
# ENVELOPE_LOCAL_MASTER_KEY=        # dev-only stable master key seed

# --- Rust ingest service (rowbound-rust-ingest-service-plan.md) --------------
# Python stays authoritative until cutover. SHADOW logs parity; RUST_ENABLED is
# the P2 cutover flag. INGEST_RUST_URL points at the Rust sync /ingest endpoint;
# INGEST_INTERNAL_TOKEN is the shared secret gating /ingest + /internal callbacks.
# INGEST_RUST_URL=http://localhost:8088
# INGEST_INTERNAL_TOKEN=dev-token
# INGEST_SHADOW_ENABLED=false
# INGEST_RUST_ENABLED=false

ACCEPTANCE_WINDOW_HOURS=72

SWEEP_ENABLED=true
SWEEP_INTERVAL_MINUTES=15

# S6 rate limiting (per-IP auth throttle). Set false to disable.
RATELIMIT_ENABLED=true

# Rust ingest service (P2). USE_STAGING_DEDUP=true computes the dedup overlap as a
# SQL anti-join over submission_key_staging instead of an in-Python set (default
# false = the proven fallback). INGEST_CALLBACK_SECRET enables /internal/ingest-result
# (the Rust worker's callback); unset = endpoint disabled.
# USE_STAGING_DEDUP=false
# INGEST_CALLBACK_SECRET=

# Malware scanning (S2). Default dev: signature scanner (catches EICAR). Set
# CLAMAV_ENABLED=true + CLAMAV_HOST/CLAMAV_PORT (or CLAMAV_SOCKET) for real ClamAV.
CLAMAV_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
