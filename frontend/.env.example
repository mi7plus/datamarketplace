# Frontend environment variables
# Copy this file to `.env` and fill in real values. Never commit the real `.env`.

# Base URL of the FastAPI backend (optional — defaults to http://localhost:3001)
NUXT_PUBLIC_API_BASE=http://localhost:3001

# Shared secret for server-side API calls — set to a real value locally, leave blank here
API_SECRET=

# Site-wide access gate (staging / private preview). Set a password to require it
# before ANY page is visible; leave UNSET to disable (normal public site). Checked
# server-side, so the password is never in the client bundle.
SITE_PASSWORD=

