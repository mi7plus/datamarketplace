# Environment secrets — never commit real values
.env
backend/.env
*.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
venv/
.venv/
*.pyc

# Node / Nuxt
node_modules/
frontend/.nuxt/
frontend/.output/
frontend/.amplify-hosting/
frontend/dist/

# OS
.DS_Store
Thumbs.db
/backend/uploads/

# @nuxt/content local store
frontend/.data/

# Portable terraform binary (local only)
infra/.bin/
infra/.terraform/
infra/.terraform.lock.hcl
# Real tfvars (env config) — only the *.example is committed
infra/*.tfvars

# Rust build artifacts
ingest-service/target/
# Portable media binaries (local only — prod installs ffmpeg/fpcalc in the image)
ingest-service/.bin/
rust-ingest/target/
rust-ingest/.bin/
